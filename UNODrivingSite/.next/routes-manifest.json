    },
    {
      "page": "/photo-gallery",
      "regex": "^/photo\\-gallery(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/photo\\-gallery(?:/)?$"
    },
    {
      "page": "/prices",
      "regex": "^/prices(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/prices(?:/)?$"
    },
    {
      "page": "/privacy-policy",
      "regex": "^/privacy\\-policy(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/privacy\\-policy(?:/)?$"
    },
    {
      "page": "/sitemap-page",
      "regex": "^/sitemap\\-page(?:/)?$",
      "routeKeys": {},
