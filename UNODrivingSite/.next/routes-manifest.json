    },
    {
      "page": "/code-of-conduct",
      "regex": "^/code\\-of\\-conduct(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/code\\-of\\-conduct(?:/)?$"
    },
    {
      "page": "/contact-us",
      "regex": "^/contact\\-us(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/contact\\-us(?:/)?$"
    },
    {
      "page": "/faqs",
      "regex": "^/faqs(?:/)?$",
