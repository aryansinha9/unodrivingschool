5:["$","section",null,{"className":"bg-blue-50 py-14","children":["$","div",null,{"className":"container mx-auto px-6 max-w-5xl","children":[["$","h2",null,{"className":"font-anton text-3xl uppercase mb-6 text-text-main text-center","children":["Local Roads and Driving Conditions in ","Tingalpa"]}],["$","div",null,{"className":"prose prose-lg max-w-none text-gray-700 mb-10 text-center mx-auto","children":[["$","p","0",{"children":"Looking for driving lessons in Tingalpa? UNO Driving School provides calm, automatic driving lessons for learners across Tingalpa, Wynnum West, Cannon Hill and Murarrie. Our 5-star instructors help Tingalpa students pass their Queensland driving test on the first attempt."}],["$","p","1",{"children":"Tingalpa is a mid-eastern suburban area with a road environment that transitions from quiet residential streets near Tingalpa Creek to the busier Old Cleveland Road corridor. Old Cleveland Road is an important multi-lane arterial with complex intersections, traffic lights, shopping precincts and heavy industrial vehicle traffic near the eastern business and warehouse precincts — making it an excellent arterial training road for building real-world driving confidence."}],["$","p","2",{"children":"The Gateway Motorway runs along Tingalpa's eastern boundary, and the surrounding service roads and on-ramp approaches provide our instructors with a unique opportunity to build motorway awareness skills in a controlled, progressive way. This motorway-adjacent training is particularly valuable for Tingalpa learners who plan to drive regularly toward the Gold Coast or airport corridor."}],["$","p","3",{"children":"Tingalpa learners test at the Greenslopes Transport and Main Roads Centre. Free pickup from Tingalpa, modern automatic vehicles, Afterpay available. Book your lesson today."}]]}],["$","ul",null,{"className":"grid md:grid-cols-2 gap-4","children":[["$","li","0",{"className":"bg-white rounded-xl p-5 shadow-sm border border-blue-100 flex items-sta