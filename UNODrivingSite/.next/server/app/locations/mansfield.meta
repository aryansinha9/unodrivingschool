{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/locations/layout,_N_T_/locations/[suburb]/layout,_N_T_/locations/[suburb]/page,_N_T_/locations/mansfield"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/locations/$d$suburb/__PAGE__",
    "/locations/$d$suburb",
    "/locations",
    "/_index",
    "/_head"
  ]
}