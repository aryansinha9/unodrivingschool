5:["$","section",null,{"className":"bg-blue-50 py-14","children":["$","div",null,{"className":"container mx-auto px-6 max-w-5xl","children":[["$","h2",null,{"className":"font-anton text-3xl uppercase mb-6 text-text-main text-center","children":["Local Roads and Driving Conditions in ","Lytton"]}],["$","div",null,{"className":"prose prose-lg max-w-none text-gray-700 mb-10 text-center mx-auto","children":[["$","p","0",{"children":"Looking for driving lessons in Lytton? UNO Driving School provides calm, automatic driving lessons for learners across Lytton, Hemmant, Wynnum and the Port of Brisbane. Our 5-star instructors help Lytton students pass their Queensland driving test on the first attempt."}],["$","p","1",{"children":"Lytton is a starkly industrial suburb heavily defined by its proximity to the Port of Brisbane and the enormous Ampol oil refinery. Because it contains virtually zero residential housing, the driving environment is dominated by massive, straight arterials and near-constant heavy vehicle movement."}],["$","p","2",{"children":"Our instructors use Lytton as an advanced isolation zone. Because the roads are so incredibly wide and free of pedestrian or residential nuance, a student can focus entirely on perfecting their high-speed lane control and heavy vehicle hazard perception. This robust, defensive training perfectly prepares them for the Wynnum TMR test."}],["$","p","3",{"children":"Lytton area learners sit their practical assessment at the Wynnum TMR Customer Service Centre. Free pickup from surrounding bayside suburbs, modern automatic vehicles, Afterpay available. Book today."}]]}],["$","ul",null,{"className":"grid md:grid-cols-2 gap-4","children":[["$","li","0",{"className":"bg-white rounded-xl p-5 shadow-sm border border-blue-100 flex items-start gap-4","children":[["$","span",null,{"className":"text-primary text-xl mt-0.5","children":"📍"}],["$","div",null,{"children":[["$","strong",null,{"className":"text-gray-900 block mb-1","children":"Lytt