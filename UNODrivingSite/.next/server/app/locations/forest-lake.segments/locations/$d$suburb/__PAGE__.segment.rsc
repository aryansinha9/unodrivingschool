4:["$","section",null,{"className":"container mx-auto px-6 py-12 max-w-4xl text-center","children":["$","p",null,{"className":"text-gray-700 text-lg leading-relaxed","children":["Learning to drive in ","Forest Lake","? UNO Driving School offers professional automatic driving lessons tailored to your skill level. Our patient instructors focus on building safe, confident drivers, helping students pass their Queensland driving test on the first go."]}]}]
5:["$","section",null,{"className":"bg-blue-50 py-14","children":["$","div",null,{"className":"container mx-auto px-6 max-w-5xl","children":[["$","h2",null,{"className":"font-anton text-3xl uppercase mb-6 text-text-main text-center","children":["Local Roads and Driving Conditions in ","Forest Lake"]}],["$","div",null,{"className":"prose prose-lg max-w-none text-gray-700 mb-10 text-center mx-auto","children":[["$","p","0",{"children":"Looking for driving lessons in Forest Lake? UNO Driving School provides calm, automatic driving lessons for learners across Forest Lake, Richlands, Inala and Sinnamon Park. Our 5-star instructors help Forest Lake students pass their Queensland driving test on the first attempt."}],["$","p","1",{"children":"Forest Lake is a master-planned outer-western suburb built around its namesake lake — a road environment that combines wide, well-signposted estate roads with a logical and consistent street network that makes it particularly effective for learner driver training. The suburb's internal road design includes multiple roundabouts, clear line markings, and residential speed zones that give learners a comprehensive introduction to Brisbane suburban road management."}],["$","p","2",{"children":"Forest Lake Boulevard is the suburb's main internal arterial — moderately busy, dual-lane, and featuring the Forest Lake Shopping Centre and several pedestrian crossings. Our instructors use this boulevard as the key mid-lesson training road, building pedestrian awareness, car park access management, and multi-lane confidence across lessons three through seven. The Centenary Highway on the suburb's northern boundary introduces motorway-adjacent training for advanced lesson stages."}],["$","p","3",{"children":"Forest Lake learners test at the Woolloongabba or Acacia Ridge centre. Free pickup from Forest Lake, Afterpay available. Book your lesson today."}]]}],["$","ul",null,{"className":"grid md:grid-cols-2 gap-4","children":[["$","li","0",{"className"