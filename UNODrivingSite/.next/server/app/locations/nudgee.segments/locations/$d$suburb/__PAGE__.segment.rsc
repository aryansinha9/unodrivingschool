4:["$","section",null,{"className":"container mx-auto px-6 py-12 max-w-4xl text-center","children":["$","p",null,{"className":"text-gray-700 text-lg leading-relaxed","children":["Learning to drive in ","Nudgee","? UNO Driving School offers professional automatic driving lessons tailored to your skill level. Our patient instructors focus on building safe, confident drivers, helping students pass their Queensland driving test on the first go."]}]}]
5:["$","section",null,{"className":"bg-blue-50 py-14","children":["$","div",null,{"className":"container mx-auto px-6 max-w-5xl","children":[["$","h2",null,{"className":"font-anton text-3xl uppercase mb-6 text-text-main text-center","children":["Local Roads and Driving Conditions in ","Nudgee"]}],["$","div",null,{"className":"prose prose-lg max-w-none text-gray-700 mb-10 text-center mx-auto","children":[["$","p","0",{"children":"Looking for driving lessons in Nudgee? UNO Driving School provides calm, automatic driving lessons for learners across Nudgee, Banyo, Boondall and Virginia. Our 5-star instructors help Nudgee students pass their Queensland driving test on the first attempt."}],["$","p","1",{"children":"Nudgee is defined by quiet residential pockets bordered by massive expanses of wetland and the major road networks of the Gateway Motorway. Driving in Nudgee offers an incredibly stark contrast: students can learn fundamental steering on the very quiet roads hugging the golf courses, then immediately practice high-speed merging on the interstate ramps."}],["$","p","2",{"children":"Our instructors capitalise on this contrast. A typical progression involves mastering reversing and parallel parking in the undisturbed Nudgee backstreets before transitioning onto Nudgee Road. From there, the student is routed through the heavy industrial traffic of Banyo, perfectly simulating the intense conditions required to pass a practical test at Zillmere or Carseldine."}],["$","p","3",{"children":"Nudgee learners sit their practical tests at the Zillmere TMR. Free pickup from Nudgee, modern automatic vehicles, Afterpay available. Book today."}]]}],["$","ul",null,{"className":"grid md:grid-cols-2 gap-4","children":[["$","li","0",{"className":"bg-white rounded-xl p-5 shadow-sm border border-blue-100 flex items-start gap-4","children":[["$","span",null,{"className":"text-primary text-xl mt-0.5","children":"📍"}],["$","div",null,{"children":[["$","strong",null,{"className":"text-gray-900 block mb-1","children":"Nudgee residential pockets"}],["$","span",null,{"className":"text-gray-600 text-sm capitalize-first","children":"Immensely quiet, flat clusters perfect for mastering foundational U-turns and precise parking without traffic pressure"}]]}]]}],["$","li","1",{"className":"bg-white rounded-xl p-5 shadow-sm border border-blue-100 flex items-start gap-4","children":[["$","span",null,{"className":"text-primary text-xl mt-0.5","children":"📍"}],["$","div",null,{"children":[["$","strong",null,{"className":"text-gray-900 block mb-1","children":"Nudgee Road"}],["$","span",null,{"className":"text-gray-600 text-sm capitalize-first","children":"Critical local arterial demanding continuous speed control and tight multi-lane lane selection"}]]}]]}],["$","li","2",{"className":"bg-white rounded-xl p-5 shadow-sm border border-blue-100 flex items-start gap-4","children":[["$","span",null,{"className":"text-primary text-xl mt-0.5","children":"📍"}],["$","div",null,{"children":[["$","strong",null,{"className":"text-gray-900 block mb-1","children":"Gateway Motorway Nudgee ramps"}],["$","span",null,{"className":"text-gray-600 text-sm capitalize-first","children":"Massive infrastructure demanding acute high-speed hazard perception"}]]}]]}],["$","li","3",{"className":"bg-white rounded-xl p-5 shadow-sm border border-blue-100 flex items-start gap-4","children":[["$","span",null,{"className":"text-primary text-xl mt-0.5","children":"📍"}],["$","div",null,{"children":[["$","strong",null,{"className":"text-gray-900 block mb-1","children":"Nudgee Golf Course boundaries"}],["$","span",null,{"className":"text-gray-600 text-sm capitalize-first","children":"Scenic, distraction-free stretches offering varied unkerbed surface practice"}]]}]]}],["$","li","4",{"className":"bg-white rounded-xl p-5 shadow-sm border border-blue-100 flex items-start gap-4","children":["$Ld","$Le"]}],"$Lf"]}]]}]}]
