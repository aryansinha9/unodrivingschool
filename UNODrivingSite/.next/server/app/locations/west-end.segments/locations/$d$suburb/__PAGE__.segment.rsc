4:["$","section",null,{"className":"container mx-auto px-6 py-12 max-w-4xl text-center","children":["$","p",null,{"className":"text-gray-700 text-lg leading-relaxed","children":["Learning to drive in ","West End","? UNO Driving School offers professional automatic driving lessons tailored to your skill level. Our patient instructors focus on building safe, confident drivers, helping students pass their Queensland driving test on the first go."]}]}]
5:["$","section",null,{"className":"bg-blue-50 py-14","children":["$","div",null,{"className":"container mx-auto px-6 max-w-5xl","children":[["$","h2",null,{"className":"font-anton text-3xl uppercase mb-6 text-text-main text-center","children":["Local Roads and Driving Conditions in ","West End"]}],["$","div",null,{"className":"prose prose-lg max-w-none text-gray-700 mb-10 text-center mx-auto","children":[["$","p","0",{"children":"Looking for professional driving lessons in West End? UNO Driving School offers calm, supportive, automatic driving lessons for learners across West End, South Brisbane, Dutton Park and Highgate Hill. Our experienced, 5-star rated instructors are passionate about helping nervous drivers build real confidence on the road."}],["$","p","1",{"children":"West End is one of Brisbane's most vibrant and unique inner-city suburbs, and learning to drive here gives you excellent preparation for real-world city driving. The mix of narrow heritage streets, busy cafe strips on Boundary Street, active weekend markets at Davies Park, and proximity to major roads like Montague Road ensures your lessons cover a genuinely diverse range of traffic situations."}],["$","p","2",{"children":"West End's pedestrian-heavy streets and the ever-present bike lanes make observation and scanning skills especially important. Our instructors specifically use West End's road environment to train your hazard perception — one of the key competencies assessed in the Queensland practical driving test. By the time you sit your test, responding to cyclists, pedestrians and unexpected hazards will feel instinctive."}],["$","p","3",{"children":"We know West End learners often have busy, flexible schedules. That is why our booking system is designed around you — lessons are available seven days a week, in slots that suit your life. We offer free pickup from anywhere in West End and the surrounding suburbs, use Afterpay for payment flexibility, and provide a fully insured, dual-controlled automatic vehicle on every lesson."}],["$","p","4",{"children":"UNO Driving School is proud of our record in West End and across Brisbane's inner south. Our calm, jargon-free teaching style has helped hundreds of West End students pass their test first go and driving with genuine confidence long after their licence is in their wallet. Book your first lesson in West End today."}]]}],["$","ul",null,{"className":"grid md:grid-cols-2 gap-4","children":[["$","li","0",{"className":"bg-white rounded-xl p-5 shadow-sm border border-blue-100 flex items-start gap-4","children":[["$","span",null,{"className":"text-primary text-xl mt-0.5","children":"📍"}],["$","div",null,{"children":[["$","strong",null,{"className":"text-gray-900 block mb-1","children":"Boundary Street"}],["$","span",null,{"className":"text-gray-600 text-sm capitalize-first","children":"Brisbane's most famous bohemian strip, excellent for pedestrian-heavy driving practice"}]]}]]}],["$","li","1",{"className":"bg-white rounded-xl p-5 shadow-sm border border-blue-100 flex items-start gap-4","children":[["$","span",null,{"className":"text-primary text-xl mt-0.5","children":"📍"}],["$","div",null,{"children":[["$","strong",null,{"className":"text-gray-900 block mb-1","children":"Davies Park"}],["$","span",null,{"className":"text-gray-600 text-sm capitalize-first","children":"Site of the weekend markets, perfect for slow-speed and car park training"}]]}]]}],["$","li","2",{"className":"bg-white rounded-xl p-5 shadow-sm border border-blue-100 flex items-start gap-4","children":[["$","span",null,{"className":"text-primary text-xl mt-0.5","children":"📍"}],"$Ld"]}],"$Le","$Lf","$L10"]}]]}]}]
