ed automatic vehicle for your practical test at the Woolloongabba TMR centre.\"}}]}"}}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://www.unodrivingschool.com.au/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Locations\",\"item\":\"https://www.unodrivingschool.com.au/locations/\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"West End\",\"item\":\"https://www.unodrivingschool.com.au/locations/west-end/\"}]}"}}],["$","section",null,{"className":"bg-background-alt py-14","children":["$","div",null,{"className":"container mx-auto px-6 max-w-5xl text-center","children":[["$","div",null,{"className":"flex justify-center items-center gap-2 text-sm text-gray-500 mb-6 tracking-wide","children":[["$","$L2",null,{"href":"/","className":"hover:text-primary transition-colors","children":"Home"}],["$","span",null,{"children":"›"}],["$","$L2",null,{"href":"/locations","className":"hover:text-primary transition-colors","children":"Locations"}],["$","span",null,{"children":"›"}],["$","span",null,{"className":"text-gray-900 font-medium","children":"West End"}]]}],["$","p",null,{"className":"text-primary font-bold uppercase tracking-widest text-sm mb-3","children":["UNO Driving School · ","Inner Brisbane"]}],["$","h1",null,{"className":"font-anton text-4xl md:text-5xl text-text-main uppercase mb-6 leading-tight","children":["Driving Lessons in ","West End"]}],["$","div",null,{"className":"flex justify-center flex-col sm:flex-row gap-4","children":[["$","$L2",null,{"href":"/contact-us","className":"bg-primary text-white px-8 py-3 rounded-full font-anton uppercase text-lg hover:bg-green-600 transition-colors shadow-lg","children":"Book Now"}],"$L3"]}]]}]}],"$L4","$L5","$L6","$L7","$L8","$L9","$La"]}],["$Lb"],"$Lc"]}],"loading":null,"isPartial":false}
