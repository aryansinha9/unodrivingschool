1a:["$","section",null,{"className":"container mx-auto px-6 py-12 max-w-4xl text-center","children":["$","p",null,{"className":"text-gray-700 text-lg leading-relaxed","children":["Learning to drive in ","Kagaru","? UNO Driving School offers professional automatic driving lessons tailored to your skill level. Our patient instructors focus on building safe, confident drivers, helping students pass their Queensland driving test on the first go."]}]}]
1b:["$","section",null,{"className":"bg-blue-50 py-14","children":["$","div",null,{"className":"container mx-auto px-6 max-w-5xl","children":[["$","h2",null,{"className":"font-anton text-3xl uppercase mb-6 text-text-main text-center","children":["Local Roads and Driving Conditions in ","Kagaru"]}],["$","div",null,{"className":"prose prose-lg max-w-none text-gray-700 mb-10 text-center mx-auto","children":[["$","p","0",{"children":"Learning to drive in Kagaru requires a solid understanding of local traffic patterns and street layouts. From mastering the fundamentals on quieter residential roads to navigating more complex arterials, our instructors design each lesson to match your current skill level and confidence."}],["$","p","1",{"children":"Safety is our absolute priority. We focus intensely on hazard perception, defensive driving techniques, and smooth vehicle control. By practising in real Kagaru conditions, you'll develop the mechanical memory and situational awareness required to handle unexpected traffic scenarios safely."}],["$","p","2",{"children":"Our curriculum is fully aligned with Queensland Transport requirements. Whether you are logging your mandatory hours, preparing for the practical driving test, or polishing specific maneuvers like reverse parallel parking, we provide structured, patient guidance entirely tailored to your learning pace in Kagaru."}]]}],["$","ul",null,{"className":"grid md:grid-cols-2 gap-4","children":[["$","li","0",{"className":"bg-white rounded-xl p-5 shadow-sm border border-blue-100 flex items-start gap-4","children":[["$","span",null,{"className":"text-primary text-xl mt-0.5","children":"📍"}],["$","div",null,{"children":[["$","strong",null,{"className":"text-gray-900 block mb-1","children":"Local School Zones"}],["$","span",null,{"className":"text-gray-600 text-sm capitalize-first","children":"Essential for practicing speed management and hazard awareness"}]]}]]}],["$","li","1",{"className":"bg-white rounded-xl p-5 shadow-sm bo