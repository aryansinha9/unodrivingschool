4:["$","section",null,{"className":"container mx-auto px-6 py-12 max-w-4xl text-center","children":["$","p",null,{"className":"text-gray-700 text-lg leading-relaxed","children":["Learning to drive in ","Murarrie","? UNO Driving School offers professional automatic driving lessons tailored to your skill level. Our patient instructors focus on building safe, confident drivers, helping students pass their Queensland driving test on the first go."]}]}]
5:["$","section",null,{"className":"bg-blue-50 py-14","children":["$","div",null,{"className":"container mx-auto px-6 max-w-5xl","children":[["$","h2",null,{"className":"font-anton text-3xl uppercase mb-6 text-text-main text-center","children":["Local Roads and Driving Conditions in ","Murarrie"]}],["$","div",null,{"className":"prose prose-lg max-w-none text-gray-700 mb-10 text-center mx-auto","children":[["$","p","0",{"children":"Looking for driving lessons in Murarrie? UNO Driving School provides calm, automatic driving lessons for learners across Murarrie, Cannon Hill, Morningside and Tingalpa. Our 5-star instructors help Murarrie students pass their Queensland driving test on the first attempt."}],["$","p","1",{"children":"Murarrie is a predominantly industrial suburb on Brisbane's inner east, positioned between the Gateway Motorway and the Lytton Road corridor. For learner drivers, the industrial nature of the suburb creates a valuable heavy-vehicle awareness training environment — wide access roads, frequent large vehicles, and the spatial challenges of driving in a precinct designed for heavy freight. Our instructors use Murarrie's broader industrial streets deliberately to develop the clearance awareness and positioning skills that Brisbane's road network demands."}],["$","p","2",{"children":"The Lytton Road frontage provides excellent arterial training — a fast, multi-lane corridor with merging lanes, industrial access points, and significant truck traffic. This road bridges the transition from Murarrie's internal street environment to the more complex port-adjacent road network to the east. Our instructors build Lytton Road into lessons progressively once residential and light industrial driving is comfortable."}],["$","p","3",{"children":"Murarrie learners test at the Greenslopes Transport and Main Roads Centre. Free pickup from Murarrie, Afterpay available. Book your lesson today."}]]}],["$","ul",null,{"className":"grid md:grid-cols-2 gap-4","children":[["$","li","0",{"className":"bg-white rounded-xl p-5 shadow-sm border border-blue-100 flex items-start gap-4","children":[["$","span",null,{"className":"text-primary text-xl mt-0.5","children":"📍"}],["$","div",null,{"children":[["$","strong",null,{"className":"text-gray-900 block mb-1","children":"Lytton Road"}],["$","span",null,{"className":"text-gray-600 text-sm capitalize-first","children":"Main arterial for multi-lane driving, merging and heavy vehicle awareness"}]]}]]}],["$","li","1",{"className":"bg-white rounded-xl p-5 shadow-sm border border-blue-100 flex items-start gap-4","children":[["$","span",null,{"className":"text-primary text-xl mt-0.5","children":"📍"}],["$","div",null,{"children":[["$","strong",null,{"className":"text-gray-900 block mb-1","children":"Murarrie industrial precincts"}],["$","span",null,{"className":"text-gray-600 text-sm capitalize-first","children":"Wide access roads for clearance and positioning practice"}]]}]]}],["$","li","2",{"className":"bg-white rounded-xl p-5 shadow-sm border border-blue-100 flex items-start gap-4","children":[["$","span",null,{"className":"text-primary text-xl mt-0.5","children":"📍"}],["$","div",null,{"children":[["$","strong",null,{"className":"text-gray-900 block mb-1","children":"Gateway Motorway service roads"}],["$","span",null,{"className":"text-gray-600 text-sm capitalize-first","children":"Motorway-adjacent driving for highway confidence"}]]}]]}],["$","li","3",{"className":"bg-white rounded-xl p-5 shadow-sm border border-blue-100 flex items-start gap-4","children":[["$","span",null,{"className":"text-primary text-xl mt-0.5","children":"📍"}],["$","div",null,{"children":[["$","strong",null,{"className":"text-gray-900 block mb-1","children":"Cannon Hill boundary roads"}],"$Ld"]}]]}],"$Le","$Lf"]}]]}]}]
