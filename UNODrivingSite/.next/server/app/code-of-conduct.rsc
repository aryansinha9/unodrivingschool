b:["$","div",null,{"className":"border-t border-gray-800 pt-8","children":["$","div",null,{"className":"flex flex-col items-center gap-10 pb-10","children":[["$","p",null,{"className":"text-gray-500 text-sm text-center","children":["© ",2026," UNO Driving School. All rights reserved."]}],["$","div",null,{"className":"w-full h-24 relative opacity-30 overflow-hidden rounded-lg","children":["$","a",null,{"href":"https://anantasystems.com.au/","target":"_blank","rel":"noopener noreferrer","className":"block w-full h-full cursor-pointer","children":["$","$L10",null,{"shapeSize":1.4,"borderSize":0.12}]}]}]]}]}]
